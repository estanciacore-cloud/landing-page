---
import { Image } from "astro:assets";
import Footer from "~/components/footer.astro";
import Header from "~/components/header.astro";
import logoSvg from "~/assets/logo no fondo.svg";
import "~/styles/index.css";

const { generator, site } = Astro;
const image = new URL("social.jpg", site);
const description =
  "Estancia Core - Proveedor oficial de tecnología WhatsApp Business API. Automatización escalable para tu negocio.";
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={generator} />

    <title>Estancia Core - WhatsApp Business API Provider</title>
    <meta name="description" content={description} />

    <meta property="og:title" content="Estancia Core - WhatsApp Business API" />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={site} />
    <meta name="twitter:card" content="summary_large_image" />

    <script is:inline>
      const themeSaved = localStorage.getItem("theme");
      if (themeSaved) {
        document.documentElement.dataset.theme = themeSaved;
      } else {
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        document.documentElement.dataset.theme = prefersDark ? "dark" : "light";
      }
    </script>
  </head>
  <body class="min-h-screen bg-black text-gray-300 antialiased">
    <Header />

    <main>
      <section class="relative flex min-h-[90vh] flex-col items-center justify-center overflow-hidden px-6 text-center">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(59,130,246,0.12)_0%,_transparent_70%)] animate-pulse-slow"></div>
        
        <div class="absolute inset-0 opacity-30">
          <div class="absolute left-1/4 top-1/4 h-64 w-64 rounded-full bg-primary/20 blur-[100px] animate-float"></div>
          <div class="absolute bottom-1/4 right-1/4 h-48 w-48 rounded-full bg-secondary/15 blur-[80px] animate-float-delayed"></div>
        </div>

        <div class="relative z-10 mx-auto max-w-4xl">
          <div class="mb-6 flex justify-center">
            <Image src={logoSvg} alt="Estancia Core" class="h-20 w-auto animate-fade-in" />
          </div>
          
          <span class="mb-6 inline-block rounded-full border border-primary/30 bg-primary/10 px-4 py-1.5 text-sm text-primary">
            Proveedor Oficial WhatsApp Business API
          </span>
          
          <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl md:text-6xl">
            Automatización oficial y escalable para
            <span class="text-primary"> WhatsApp Business</span>
          </h1>
          
          <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-400">
            Implementamos soluciones de comunicación automatizada mediante la API oficial de WhatsApp Business.
            Chatbots inteligentes, integración con CRM y sistemas de alta disponibilidad.
          </p>
          
          <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:justify-center">
            <a
              href="mailto:info@estanciacore.net.ar"
              class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-6 py-3 font-semibold text-white transition-all hover:bg-primary/90 animate-slide-up"
            >
              Consultar Demo
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L11.586 11H3a1 1 0 110-2h8.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </a>
            <a
              href="https://wa.me/542665035855"
              class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/20 bg-white/5 px-6 py-3 font-semibold text-white transition-all hover:bg-white/10 animate-slide-up-delayed"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zm-1-2.5c-.276 0-.5.224-.5.5v2h1v-2c0-.276-.224-.5-.5-.5z" clip-rule="evenodd" />
              </svg>
              Escribinos
            </a>
          </div>
        </div>
      </section>

      <section class="px-6 py-24">
        <div class="mx-auto max-w-6xl">
          <h2 class="text-center text-3xl font-bold text-white">
            Tres pilares para tu comunicación
          </h2>
          
          <div class="mt-16 grid gap-8 md:grid-cols-3">
            <div class="rounded-xl border border-white/10 bg-white/5 p-8 transition-all hover:border-primary/30">
              <div class="mb-4 inline-flex size-12 items-center justify-center rounded-lg bg-primary/20">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16M15 16c1.5 0 3-1 3-3s-1.5-3-3-3-3 1-3 3 1.5 3 3 3z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-white">Chatbots inteligentes</h3>
              <p class="mt-3 text-gray-400">
                Asistentes virtuales entrenados para WhatsApp que automatizan respuestas, cualifican leads y operan 24/7 sin intervención humana.
              </p>
            </div>
            
            <div class="rounded-xl border border-white/10 bg-white/5 p-8 transition-all hover:border-primary/30">
              <div class="mb-4 inline-flex size-12 items-center justify-center rounded-lg bg-primary/20">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-white">Integración CRM</h3>
              <p class="mt-3 text-gray-400">
                Conexión directa con tu CRM, base de datos o sistemaERP. Sincronización de contactos, oportunidades y historique de conversaciones.
              </p>
            </div>
            
            <div class="rounded-xl border border-white/10 bg-white/5 p-8 transition-all hover:border-primary/30">
              <div class="mb-4 inline-flex size-12 items-center justify-center rounded-lg bg-primary/20">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-white">Alta disponibilidad</h3>
              <p class="mt-3 text-gray-400">
                Infraestructura diseñada para funcionar siempre. Monitoreo continuo, reintentos automáticos y soporte prioritario para tu tranquilidad.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="border-t border-white/5 bg-black/50 px-6 py-16">
        <div class="mx-auto max-w-3xl text-center">
          <h3 class="text-xl font-semibold text-white">Cumplimiento con Meta</h3>
          <p class="mt-4 text-gray-400">
            Nuestras soluciones operan bajo las <strong>Políticas de Comercio de Meta</strong> para WhatsApp Business.
            Cumplimos estrictamente con las guidelines de consentimiento, tasas de mensajes y opt-out.
            No utilizamos prácticas de spam ni mensajes masivos no solicitados.
          </p>
          <div class="mt-6 flex flex-wrap justify-center gap-4 text-sm">
            <a href="/privacy-policy" class="text-primary hover:underline">Política de Privacidad</a>
            <span class="text-gray-600">|</span>
            <a href="/terms-of-service" class="text-primary hover:underline">Términos de Servicio</a>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>