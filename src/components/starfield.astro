<div id="starfield" class="absolute inset-0">
  <canvas id="starfield-canvas"></canvas>
</div>

<script>
  import invariant from "tiny-invariant";

  const COUNT = 400;
  const SPEED = 0.3;
  const DEPTH = 150;

  interface Star {
    x: number;
    y: number;
    z: number;
    xPrev: number;
    yPrev: number;
    size: number;
    opacity: number;
  }

  class Star {
    x: number;
    y: number;
    z: number;
    xPrev: number;
    yPrev: number;
    size: number;
    opacity: number;

    constructor(x = 0, y = 0, z = 0) {
      this.x = x;
      this.y = y;
      this.z = z;
      this.xPrev = x;
      this.yPrev = y;
      this.size = Math.random() * 2 + 0.5;
      this.opacity = Math.random() * 0.8 + 0.2;
    }

    update(width: number, height: number, speed: number) {
      this.xPrev = this.x;
      this.yPrev = this.y;
      this.z -= speed * 0.1;

      if (this.z <= 0) {
        this.reset(width, height);
      } else {
        const scale = DEPTH / this.z;
        this.x = this.xPrev * scale;
        this.y = this.yPrev * scale;
      }
    }

    reset(width: number, height: number) {
      this.x = Math.random() * width - width / 2;
      this.y = Math.random() * height - height / 2;
      this.xPrev = this.x;
      this.yPrev = this.y;
      this.z = DEPTH;
      this.size = Math.random() * 2 + 0.5;
      this.opacity = Math.random() * 0.8 + 0.2;
    }

    draw(ctx: CanvasRenderingContext2D, centerX: number, centerY: number) {
      const scale = DEPTH / this.z;
      const x = this.xPrev * scale + centerX;
      const y = this.yPrev * scale + centerY;
      const radius = this.size * scale * 0.5;

      if (radius < 0.1 || x < 0 || x > ctx.canvas.width || y < 0 || y > ctx.canvas.height) {
        return;
      }

      const gradient = ctx.createRadialGradient(x, y, 0, x, y, radius);
      const alpha = Math.min(this.opacity * scale / DEPTH * 2, 1);
      gradient.addColorStop(0, `rgba(255, 255, 255, ${alpha})`);
      gradient.addColorStop(0.5, `rgba(200, 220, 255, ${alpha * 0.6})`);
      gradient.addColorStop(1, 'rgba(255, 255, 255, 0)');

      ctx.fillStyle = gradient;
      ctx.beginPath();
      ctx.arc(x, y, radius, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  const stars: Star[] = Array.from({ length: COUNT }, () => {
    const star = new Star(0, 0, 0);
    star.z = Math.random() * DEPTH;
    return star;
  });

  let rafId = 0;

  const canvas = document.querySelector("#starfield-canvas") as HTMLCanvasElement;
  invariant(canvas, "canvas should not be null");
  const ctx = canvas.getContext("2d");

  const container = document.querySelector("#starfield") as HTMLElement;
  invariant(container, "container should not be null");
  const resizeObserver = new ResizeObserver(setup);
  resizeObserver.observe(container);

  function setup() {
    invariant(ctx, "canvas context should not be null");
    rafId > 0 && cancelAnimationFrame(rafId);

    const { clientWidth: width, clientHeight: height } = container;
    const dpr = window.devicePixelRatio || 1;
    canvas.width = width * dpr;
    canvas.height = height * dpr;
    canvas.style.width = `${width}px`;
    canvas.style.height = `${height}px`;
    ctx.scale(dpr, dpr);

    rafId = requestAnimationFrame(frame);
  }

  function frame() {
    invariant(ctx, "canvas context should not be null");
    const { clientWidth: width, clientHeight: height } = container;

    ctx.fillStyle = "rgba(10, 10, 15, 0.15)";
    ctx.fillRect(0, 0, width, height);

    const centerX = width / 2;
    const centerY = height / 2;

    for (const star of stars) {
      star.update(width, height, SPEED);
      star.draw(ctx, centerX, centerY);
    }

    rafId = requestAnimationFrame(frame);
  }

  setup();
</script>

<style>
  #starfield {
    background: linear-gradient(180deg, #0a0a1a 0%, #050510 100%);
  }

  #starfield::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center bottom, rgba(139, 92, 246, 0.15) 0%, transparent 70%);
    pointer-events: none;
  }
</style>