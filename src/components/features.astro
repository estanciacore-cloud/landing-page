---
import { Icon } from "astro-icon/components";
import ContentSection from "~/components/content-section.astro";
import type { FeatureItem } from "~/types";

const features: Array<FeatureItem> = [
  {
    title: "Cámaras de Seguridad",
    description:
      "Instalación de sistemas de videovigilancia IP, cámaras ocultas y sistemas de grabación 24/7.",
    icon: "mdi:cctv",
  },
  {
    title: "Alarmas y Seguridad",
    description:
      "Sistemas de alarmas monitoreadas, sensores de movimiento, detectores de humo y gas.",
    icon: "mdi:shield-lock",
  },
  {
    title: "Redes WiFi",
    description:
      "Infraestructura de redes cableadas e inalámbricas, puntos de acceso, routers y soluciones mesh.",
    icon: "mdi:wifi",
  },
  {
    title: "Domótica",
    description:
      "Automatización del hogar: luces, termostatos, persianas, cerraduras inteligentes.",
    icon: "mdi:home-automation",
  },
  {
    title: "Automatizaciones",
    description:
      "Programación de escenarios y rutinas automatizadas para tu hogar o negocio.",
    icon: "mdi:robot",
  },
  {
    title: "Soluciones con IA",
    description:
      "Implementación de asistentes virtuales, análisis de video inteligente y automatización avanzada.",
    icon: "mdi:brain",
  },
];
---

<ContentSection title="Nuestros Servicios" id="features">
  <Fragment slot="lead">
    Ofrecemos <span class="text-primary">soluciones integrales</span> para tu hogar o negocio.
    Desde la instalación de <span class="text-primary">infraestructura</span> hasta sistemas <span class="text-primary">inteligentes</span>.
  </Fragment>
  <ul class="grid max-w-6xl grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      features.map(({ title, description, icon }) => (
        <li class="group flex flex-col items-center gap-4 rounded-2xl border border-white/10 bg-gradient-to-br from-white/5 to-transparent p-8 backdrop-blur-sm transition-all duration-300 hover:border-primary/50 hover:shadow-[0_0_30px_rgba(236,72,153,0.15)]">
          <div class="size-16 rounded-full border border-primary/30 bg-gradient-to-br from-primary/20 to-transparent p-4 transition-transform duration-300 group-hover:scale-110 group-hover:border-primary/60">
            <Icon name={icon} class="size-full text-primary" />
          </div>
          <p class="text-center text-lg font-medium">{title}</p>
          <p class="text-center text-sm text-text-offset">{description}</p>
        </li>
      ))
    }
  </ul>
</ContentSection>