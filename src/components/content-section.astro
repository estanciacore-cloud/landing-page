---
export interface Props {
  id: string;
  title: string;
}

const { title, id } = Astro.props;
---

<section
  id={id}
  class="flex scroll-mt-24 flex-col items-center gap-4 space-y-8 px-4"
>
  <div class="flex flex-col items-center gap-4">
    <slot name="eyebrow" />
    <h2
      class="gradient-text text-center font-bold tracking-tight text-4xl md:text-5xl"
    >
      {title}
    </h2>
  </div>
  <p class="max-w-xl text-center text-lg text-text-offset md:text-xl">
    <slot name="lead" />
  </p>
  <slot />
</section>
