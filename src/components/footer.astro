---
import { Icon } from "astro-icon/components";
import type { FooterLink } from "~/types";

const links: Array<FooterLink> = [
  {
    url: "mailto:info@estanciacore.net.ar",
    description: "Envianos un email",
    icon: "mdi:email",
  },
  {
    url: "https://wa.me/542665035855",
    description: "Escribinos por WhatsApp",
    icon: "mdi:whatsapp",
  },
  {
    url: "tel:+542665035855",
    description: "Llamanos",
    icon: "mdi:phone",
  },
  {
    url: "https://instagram.com",
    description: "Seguinos en Instagram",
    icon: "fa-brands:instagram",
  },
];
---

<footer class="relative flex flex-col items-center justify-center gap-8 py-16">
  <ul class="flex flex-wrap justify-center gap-4">
    {
      links.map((link) => (
        <li>
          <a
            class="group flex size-14 items-center justify-center rounded-full border border-white/20 bg-white/5 p-3 text-white backdrop-blur-sm transition-all duration-300 hover:border-primary/60 hover:bg-primary/20 hover:shadow-[0_0_25px_rgba(236,72,153,0.3)]"
            href={link.url}
          >
            <span class="sr-only">{link.description}</span>
            <Icon class="size-full transition-transform duration-300 group-hover:scale-110" name={link.icon} />
          </a>
        </li>
      ))
    }
  </ul>
  <div class="text-center text-sm text-text-offset">
    <p>&copy; 2024 Estancia Core. Todos los derechos reservados.</p>
    <p class="mt-1">San Luis, Argentina</p>
  </div>
</footer>

<style>
  footer {
    background: linear-gradient(180deg, transparent 0%, rgba(139, 92, 246, 0.05) 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
</style>