---
import { Icon } from "astro-icon/components";
import ContentSection from "~/components/content-section.astro";
---

<ContentSection title="Contacto" id="contacto">
  <Fragment slot="lead">
    ¿Listo para transformar tu hogar? <span class="text-primary">Contactanos</span> y te asesoramos sin compromiso.
  </Fragment>
  <div class="flex flex-col items-center gap-6 text-center">
    <div class="flex items-center gap-3">
      <Icon name="mdi:email" class="size-8 text-primary" />
      <a href="mailto:info@estanciacore.net.ar" class="text-lg hover:underline">
        info@estanciacore.net.ar
      </a>
    </div>
    <div class="flex items-center gap-3">
      <Icon name="mdi:phone" class="size-8 text-primary" />
      <a href="tel:+542665035855" class="text-lg hover:underline">
        2665-035855
      </a>
    </div>
    <div class="flex items-center gap-3">
      <Icon name="mdi:map-marker" class="size-8 text-primary" />
      <span class="text-lg">Av. Fundador 1351 Dpto 1 - San Luis, San Luis</span>
    </div>
  </div>
</ContentSection>