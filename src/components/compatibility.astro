---
import { Icon } from "astro-icon/components";
import ContentSection from "~/components/content-section.astro";
---

<ContentSection title="Contacto" id="contacto">
  <Fragment slot="lead">
    ¿Listo para transformar tu hogar? <span class="text-primary font-semibold">Contactanos</span> y te asesoramos sin compromiso.
  </Fragment>
  <div class="flex flex-col items-center gap-6 text-center">
    <a
      href="mailto:info@estanciacore.net.ar"
      class="group flex items-center gap-3 transition-all hover:text-primary"
    >
      <div class="flex size-12 items-center justify-center rounded-full border border-primary/30 bg-primary/5 p-2 transition-all duration-300 group-hover:border-primary/60 group-hover:shadow-[0_0_20px_rgba(236,72,153,0.25)]">
        <Icon name="mdi:email" class="size-6 text-primary" />
      </div>
      <span class="text-lg">info@estanciacore.net.ar</span>
    </a>
    <a
      href="tel:+542665035855"
      class="group flex items-center gap-3 transition-all hover:text-primary"
    >
      <div class="flex size-12 items-center justify-center rounded-full border border-primary/30 bg-primary/5 p-2 transition-all duration-300 group-hover:border-primary/60 group-hover:shadow-[0_0_20px_rgba(236,72,153,0.25)]">
        <Icon name="mdi:phone" class="size-6 text-primary" />
      </div>
      <span class="text-lg">2665-035855</span>
    </a>
    <div class="flex items-center gap-3">
      <div class="flex size-12 items-center justify-center rounded-full border border-primary/30 bg-primary/5 p-2">
        <Icon name="mdi:map-marker" class="size-6 text-primary" />
      </div>
      <span class="text-lg">Av. Fundador 1351 Dpto 1 - San Luis, San Luis</span>
    </div>
  </div>
</ContentSection>