---
import type { NavItem } from "~/types";

const navItems: Array<NavItem> = [
  { title: "Privacidad", url: "/privacy-policy" },
  { title: "Términos", url: "/terms-of-service" },
];
---

<header class="fixed top-0 z-50 w-full border-b border-white/5 bg-black/60 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a class="text-xl font-bold tracking-tight text-white" href="/">
      Estancia Core
    </a>
    <nav class="flex items-center gap-6">
      <ul class="hidden sm:flex items-center gap-6">
        {
          navItems.map(({ title, url }) => (
            <li>
              <a class="text-sm text-gray-300 hover:text-white transition-colors" href={url}>
                {title}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
