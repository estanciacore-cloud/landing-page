---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import ContentSection from "~/components/content-section.astro";
import logoSvg from "~/assets/logo no fondo.svg";
---

<ContentSection title="¿Quiénes somos?" id="intro">
  <Image slot="eyebrow" src={logoSvg} alt="Estancia Core" class="size-32" />
  <Fragment slot="lead">
    Somos <span class="text-primary font-semibold">Estancia Core</span>, tu partner tecnológico en San Luis.
    Transformamos tu hogar en un espacio inteligente, seguro y conectado.
    Instalamos y configuramos infraestructura tecnológica para que vivás con tranquilidad.
  </Fragment>
  <div class="flex flex-col gap-4 sm:flex-row">
    <a
      href="mailto:info@estanciacore.net.ar"
      class="group relative flex items-center justify-center gap-3 rounded-xl border border-primary/20 bg-gradient-to-r from-primary/5 to-transparent px-8 py-4 font-medium backdrop-blur-sm transition-all duration-300 hover:border-primary/50 hover:from-primary/15 hover:shadow-[0_0_30px_rgba(236,72,153,0.25)]"
    >
      <div class="absolute inset-0 rounded-xl bg-gradient-to-r from-primary/0 to-primary/0 transition-all duration-300 group-hover:from-primary/5 group-hover:to-transparent"></div>
      <Icon name="mdi:email" class="size-6 text-primary" />
      <span>Contactanos</span>
    </a>
    <a
      href="tel:+542665035855"
      class="group relative flex items-center justify-center gap-3 rounded-xl border border-secondary/20 bg-gradient-to-r from-secondary/5 to-transparent px-8 py-4 font-medium backdrop-blur-sm transition-all duration-300 hover:border-secondary/50 hover:from-secondary/15 hover:shadow-[0_0_30px_rgba(129,140,248,0.25)]"
    >
      <div class="absolute inset-0 rounded-xl bg-gradient-to-r from-secondary/0 to-secondary/0 transition-all duration-300 group-hover:from-secondary/5 group-hover:to-transparent"></div>
      <Icon name="mdi:phone" class="size-6 text-secondary" />
      <span>Llamanos</span>
    </a>
  </div>
</ContentSection>