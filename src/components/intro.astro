---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import ContentSection from "~/components/content-section.astro";
import logoSvg from "~/assets/logo no fondo.svg";
---

<ContentSection title="¿Quiénes somos?" id="intro">
  <Image slot="eyebrow" src={logoSvg} alt="Estancia Core" class="size-32" />
  <Fragment slot="lead">
    Somos <span class="text-primary font-semibold">Estancia Core</span>, tu partner tecnológico en San Luis.
    Transformamos tu hogar en un espacio inteligente, seguro y conectado.
    Instalamos y configuramos infraestructura tecnológica para que vivás con tranquilidad.
  </Fragment>
  <div class="flex flex-col gap-4 sm:flex-row">
    <a
      href="mailto:info@estanciacore.net.ar"
      class="flex items-center justify-center gap-3 rounded-xl border border-primary/30 bg-gradient-to-r from-primary/10 to-transparent px-8 py-4 font-medium backdrop-blur-sm transition-all hover:border-primary/60 hover:shadow-[0_0_20px_rgba(236,72,153,0.2)]"
    >
      <Icon name="mdi:email" class="size-6 text-primary" />
      <span>Contactanos</span>
    </a>
    <a
      href="tel:+542665035855"
      class="flex items-center justify-center gap-3 rounded-xl border border-secondary/30 bg-gradient-to-r from-secondary/10 to-transparent px-8 py-4 font-medium backdrop-blur-sm transition-all hover:border-secondary/60 hover:shadow-[0_0_20px_rgba(129,140,248,0.2)]"
    >
      <Icon name="mdi:phone" class="size-6 text-secondary" />
      <span>Llamanos</span>
    </a>
  </div>
</ContentSection>