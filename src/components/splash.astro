---
import { Image } from "astro:assets";
import Starfield from "~/components/starfield.astro";
import logo from "../assets/logo no fondo.png";
---

<section class="relative h-full overflow-hidden">
  <Starfield />
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-primary/10 to-background"></div>
  <div class="relative z-10 flex h-full flex-col items-center justify-center px-8">
    <h1 class="mb-4 text-center text-4xl font-bold tracking-wider text-white md:text-6xl">
      ESTANCIA CORE
    </h1>
    <div class="mb-6 max-w-md animate-float">
      <Image
        src={logo}
        alt="Estancia Core"
        class="w-full object-contain drop-shadow-[0_0_30px_rgba(255,255,255,0.3)]"
      />
    </div>
    <h2 class="flex flex-col items-center gap-4">
      <p class="text-center text-2xl font-light text-white md:text-4xl animate-fade-in">
        Tu casa inteligente.<br /><span class="font-semibold">Tu mente tranquila.</span>
      </p>
    </h2>
  </div>
  <div class="absolute left-8 top-1/2 -translate-y-1/2 animate-fade-in">
    <div class="flex flex-col items-center text-white/60">
      <span class="text-sm -rotate-90 whitespace-nowrap">Deslizá para descubrir</span>
    </div>
  </div>
</section>

<style>
  section {
    min-height: 100vh;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
  .animate-fade-in {
    animation: fade-in 1s ease-out forwards;
    animation-delay: 0.3s;
    opacity: 0;
  }
</style>