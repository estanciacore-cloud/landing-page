---
import { Image } from "astro:assets";
import fondo from "../assets/fondo azul.png";
import logo from "../assets/logo estancia core sin fondo.png";
---

<section class="relative h-full">
  <div class="absolute inset-0 z-0">
    <Image
      src={fondo}
      alt="Fondo Estancia Core"
      class="h-full w-full object-cover"
    />
  </div>
  <div class="relative z-10 flex h-full flex-col items-center justify-center px-8">
    <div class="mb-6 max-w-md">
      <Image
        src={logo}
        alt="Estancia Core"
        class="w-full object-contain"
      />
    </div>
    <h2 class="flex flex-col items-center gap-4">
      <p class="text-center text-2xl font-light text-white md:text-4xl">
        Tu casa inteligente.<br /><span class="font-semibold">Tu mente tranquila.</span>
      </p>
    </h2>
  </div>
</section>

<style>
  section {
    min-height: 100vh;
  }
</style>